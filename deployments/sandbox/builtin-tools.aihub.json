    "status": "enable",
    "scope": "public",
    "version": "1.0.0",
    "labels": {"stable": "1.0.0", "latest": "1.0.0"},
    "definition": {
      "runtime": {"type": "builtin", "name": "workspace.search_text", "description": "Search workspace text."},
      "execution": {"placement": "sandbox", "runner": "builtin", "filesystem": "readonly", "network": "none", "capabilities": ["filesystem.read"]},
      "inputSchema": {"type":"object","required":["query"],"properties":{"path":{"type":"string"},"query":{"type":"string"},"glob":{"type":"string"},"maxResults":{"type":"integer"}}},
      "timeoutMillis": 15000
    }
  },
  {
    "id": "browser.open",
    "displayName": "Sandbox Browser Open",
    "description": "Open a URL in the sandbox headless browser. Requires network policy to allow destination.",
    "status": "enable",
    "scope": "public",
    "version": "1.0.0",
    "labels": {"stable": "1.0.0", "latest": "1.0.0"},
    "definition": {
      "runtime": {"type": "builtin", "name": "browser.open", "description": "Open URL in sandbox browser."},
      "execution": {"placement": "sandbox", "runner": "builtin", "filesystem": "none", "network": "restricted", "capabilities": ["browser.open", "network.egress"]},
      "inputSchema": {"type":"object","required":["url"],"properties":{"url":{"type":"string"}}},
      "timeoutMillis": 20000
    }
  }
